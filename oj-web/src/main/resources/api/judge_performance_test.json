{
  "info": {
    "name": "OJ判题链路性能测试",
    "description": "判题链路各环节性能测试用例",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. 单次提交性能测试",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('响应成功', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "console.log('提交Token:', jsonData.data.submitToken);",
              "console.log('状态:', jsonData.data.status);",
              "",
              "pm.test('返回Pending状态', function() {",
              "    pm.expect(jsonData.data.status).to.eql('Pending');",
              "});",
              "",
              "pm.test('响应时间 < 500ms', function() {",
              "    pm.expect(pm.response.responseTime).to.below(500);",
              "});",
              "",
              "pm.collectionVariables.set('submissionToken', jsonData.data.submitToken);",
              "pm.collectionVariables.set('problemId', jsonData.data.problemId);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "{{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"problemId\": 1,\n  \"language\": \"Java\",\n  \"code\": \"public class Solution { public static void main(String[] args) { System.out.println(\\\"Hello World\\\"); } }\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/user/judge/submit",
          "host": ["{{baseUrl}}"],
          "path": ["user", "judge", "submit"]
        }
      }
    },
    {
