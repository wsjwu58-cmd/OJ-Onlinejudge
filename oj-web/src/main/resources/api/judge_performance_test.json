    {
      "name": "4. 查询提交历史性能测试",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('响应成功', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "console.log('提交记录数:', jsonData.data ? jsonData.data.length : 0);",
              "console.log('响应时间:', pm.response.responseTime + 'ms');",
              "",
              "pm.test('响应时间 < 200ms', function() {",
              "    pm.expect(pm.response.responseTime).to.below(200);",
              "});"
            ]
          }
