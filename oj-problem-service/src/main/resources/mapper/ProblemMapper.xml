<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.oj.problem.mapper.ProblemMapper">
    <select id="selectPage" resultType="com.oj.problem.vo.ProblemVO">
        select p.* from problems p ${ew.customSqlSegment}
    </select>
    <select id="selectPageOf" resultType="com.oj.problem.entity.ProblemType">
        SELECT pt.*
        FROM problem_types pt
                 INNER JOIN problem_types_rel ptr ON pt.id = ptr.type_id
        WHERE ptr.problem_id = #{id}
    </select>
    <select id="selectTypeListBatch" resultType="com.oj.problem.entity.ProblemTypesRel">
        SELECT ptr.*
        FROM problem_types_rel ptr
        WHERE ptr.problem_id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>
    <select id="countProblem" resultType="java.lang.Integer">
        select count(id) from exercise.problems
        <where>
            <if test="begin!=null">
                and created_at &gt;=#{begin}
            </if>
            <if test="end!=null">
                and created_at &lt;=#{end}
            </if>
        </where>
    </select>
    <select id="countProblemDis" resultType="java.lang.Integer">
        select count(id) from problems
        <where>
            <if test="status!=null">
                and status=#{status}
            </if>
        </where>
    </select>
    <select id="selectCount10" resultType="com.oj.problem.vo.ProblemAcceptanceVO">
        select title,acceptance,id from problems
        where status=1
        order by acceptance desc
    </select>
    <select id="selectProblemTypesRel" resultType="com.oj.problem.entity.ProblemTypesRel">
        SELECT * FROM problem_types_rel
        <where>
            <if test="ew != null and ew.sqlSegment != null">
                ${ew.sqlSegment}
            </if>
        </where>
    </select>
</mapper>
