<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.oj.contest.mapper.ContestMapper">
    <!-- 微服务：不再JOIN user表，createdName通过Feign调用UserClient填充 -->
    <select id="selectPage" resultType="com.oj.contest.vo.ContestVO">
        select c.* from contests c ${ew.customSqlSegment}
    </select>

    <select id="CountContest" resultType="java.lang.Integer">
        select count(id) from contests
        <where>
            <if test="status!=null">
                and status=#{status}
            </if>
        </where>
    </select>

    <!-- 批量更新比赛状态：一次SQL替代 N 次 updateById -->
    <update id="batchUpdateStatus">
        UPDATE contests
        SET status = CASE
            WHEN start_time &gt; #{now1} THEN #{upcomingStatus}
            WHEN start_time &lt;= #{now2} AND end_time &gt; #{now2} THEN #{runningStatus}
            ELSE #{endedStatus}
        END
    </update>
</mapper>
